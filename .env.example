# Copy to .env and adjust as needed. Consumed by docker-compose (Phase 2) and the
# dbt profile (Phase 3). .env is gitignored.

# Postgres connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bitcoin
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# dbt
DBT_TARGET=dev
# Default landing schema; the generate_schema_name macro routes models into
# staging / intermediate / marts on top of this.
DBT_SCHEMA=public
