# Auto-activate the uv venv and point dbt at the project-local profiles.yml on
# entry, so `dbt` / `sqlfluff` run without the `uv run` prefix. Requires direnv
# (https://direnv.net); run `direnv allow` once. Ignore if you do not use direnv.
export DBT_PROFILES_DIR="$PWD"
if [ -d .venv ]; then
    source .venv/bin/activate
else
    echo "direnv: run 'uv sync' to create .venv, then 'direnv reload'" >&2
fi
