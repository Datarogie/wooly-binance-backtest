# Auto-activate the uv-managed virtualenv on entry, so dbt and sqlfluff run
# without the `uv run` prefix. Requires direnv (https://direnv.net); run
# `direnv allow` once after cloning. Harmless to ignore if you do not use direnv.
if [ -d .venv ]; then
    source .venv/bin/activate
else
    echo "direnv: run 'uv sync' to create .venv, then 'direnv reload'" >&2
fi
